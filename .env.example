# Required: Discord bot tokens (2 separate bots)
DISCORD_BOT_TOKEN_CLAUDE=your-claude-bot-token
DISCORD_BOT_TOKEN_CODEX=your-codex-bot-token

# Optional: Anthropic API key (if not using `claude login`)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (for Codex CLI, if not using `codex login`)
OPENAI_API_KEY=sk-...

# Optional: Assistant name (default: Andy)
ASSISTANT_NAME=Andy

# Optional: Timezone (default: auto-detected)
TZ=Asia/Seoul
