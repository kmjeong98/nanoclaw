# Required: Anthropic API key for Claude Code agent
ANTHROPIC_API_KEY=sk-ant-...

# Required: Discord bot token
DISCORD_BOT_TOKEN=...

# Optional: OpenAI API key (for Codex CLI agent)
OPENAI_API_KEY=sk-...

# Optional: Assistant name (default: Andy)
ASSISTANT_NAME=Andy

# Optional: Timezone (default: auto-detected)
TZ=Asia/Seoul
